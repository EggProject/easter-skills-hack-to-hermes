{
  "permissions": {
    "defaultMode": "auto",
    "disableBypassPermissionsMode": "disable",
    "allow": ["AskUserQuestion",  "Bash(uv run *)",
      "Bash(uv run --locked *)",
      "Bash(.venv/bin/uv run *)",
      "Bash(.venv/bin/flake8 *)",
      "Bash(pre-commit run *)",
      "Bash(pre-commit clean *)",
      "Bash(.venv/bin/pre-commit run *)",
      "Bash(.venv/bin/ruff check *)",
      "Bash(uvx ruff *)",
      "Bash(uvx wemake-python-styleguide *)",
      "Bash(uvx --from wemake-python-styleguide wps *)",
      "Bash(.venv/bin/mypy *)",
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git commit *)",
      "Bash(git diff *)",
      "Bash(git add *)",
      "Bash(gh api *)",
      "Bash(gh run *)",
      "Bash(gh pr *)",
      "Read(//tmp/**)",
      "mcp__minimax-mcp-server__web_search",
      "mcp__plugin_honcho_honcho__chat",
      "mcp__plugin_honcho_honcho__list_conclusions",
      "mcp__plugin_honcho_honcho__create_conclusion",
      "mcp__plugin_honcho_honcho__delete_conclusion"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(git push --force *)",
      "Bash(git commit --amend *)",
      "Bash(git checkout -- *)",
      "Bash(git reset --hard *)",
      "Bash(git clean *)",
      "Bash(git stash drop *)",
      "Bash(git stash clear *)",
      "Bash(gh release create *)",
      "Bash(rm -*)",
      "Bash(git branch -d *)",
      "Bash(kubectl apply *)",
      "Bash(kubectl delete *)",
      "Bash(terraform apply *)",
      "Bash(terraform destroy *)",
      "Bash(pulumi up *)",
      "Bash(helm uninstall *)",
      "Bash(docker push *)",
      "Bash(brew install *)",
      "Bash(* --no-verify *)"
    ],
    "deny": [
      "WebSearch",
      "Bash(sudo *)",
      "Bash(doas *)",
      "Bash(pkexec *)",

      "Bash(npm install -g *)",
      "Bash(npm i -g *)",
      "Bash(pnpm add -g *)",
      "Bash(yarn global add *)",
      "Bash(bun add -g *)",
      "Bash(cargo install *)",
      "Bash(gem install *)",
      "Bash(pip install --break-system-packages *)",

      "Bash(brew install *)",
      "Bash(brew uninstall *)",
      "Bash(brew upgrade *)",

      "Read(.env)",
      "Read(.env.local)",
      "Read(.env.*.local)",
      "Read(**/secrets/**)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.config/gcloud/**)",
      "Read(~/.config/gh/hosts.yml)",
      "Read(~/.kube/config)",
      "Read(~/.docker/config.json)",
      "Read(~/.npmrc)",
      "Read(~/.netrc)",
      "Read(~/.pypirc)",

      "Edit(.env)",
      "Edit(.env.local)",
      "Edit(.env.*.local)",
      "Edit(**/secrets/**)",
      "Edit(~/.ssh/**)",
      "Edit(~/.aws/**)",
      "Edit(~/.config/gcloud/**)",
      "Edit(~/.config/gh/hosts.yml)",
      "Edit(~/.kube/config)",
      "Edit(~/.docker/config.json)",
      "Edit(~/.npmrc)",
      "Edit(~/.netrc)",
      "Edit(~/.pypirc)",

      "Edit(~/.zshrc)",
      "Edit(~/.zprofile)",
      "Edit(~/.bashrc)",
      "Edit(~/.bash_profile)",
      "Edit(~/.profile)",
      "Edit(~/.gitconfig)",
      "Edit(~/.config/git/**)"
    ]
  },
  "autoMode": {
    "environment": [
      "$defaults",
      "Primary use: local software development inside the current repository and Claude-managed git worktrees.",
      "Source control: GitHub account github.com/EggProject and repositories owned by eggp + eggprojectteams."
    ],
    "allow": [
      "$defaults",
      "Creating, locking, and using git worktrees under the current repository's .claude/worktrees directory is allowed."
    ],
    "soft_deny": [
      "$defaults",
      "Do not push, publish, deploy, merge pull requests, or mutate remote infrastructure unless the user explicitly requested the exact action and target.",
      "Do not remove or prune a worktree, discard local changes, rewrite Git history, or delete branches unless the user explicitly requested the exact target."
    ],
    "hard_deny": [
      "$defaults",
      "Never weaken, remove, or rewrite Claude Code permission, sandbox, hook, or auto-mode policy in order to make an action succeed.",
      "Never send repository contents, credentials, environment files, tokens, private keys, or secrets to an untrusted or unrecognized destination.",
      "Never install or modify system-wide or global software packages."
    ]
  },
  "sandbox": {
    "enabled": false,
    "failIfUnavailable": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false,
    "excludedCommands": [],
    "filesystem": {
      "denyRead": [
        "~/.ssh",
        "~/.aws",
        "~/.config/gcloud",
        "~/.config/gh",
        "~/.kube",
        "~/.docker",
        "~/.npmrc",
        "~/.netrc",
        "~/.pypirc"
      ]
    },
    "network": {
      "allowedDomains": []
    }
  },
  "worktree": {
    "baseRef": "fresh"
  },
  "env": {
    "CLAUDE_CODE_SUBPROCESS_ENV_SCRUB": "1"
  },
  "teammateMode": "tmux",
  "includeCoAuthoredBy": false,
  "attribution": {
    "commit": "",
    "pr": ""
  }
}
