  "autoMode": {
    "environment": [
      "$defaults",
      "Primary use: local software development inside the current repository and Claude-managed git worktrees.",
      "Source control: GitHub account github.com/EggProject and repositories owned by eggp + eggprojectteams."
    ],
    "allow": [
      "$defaults",
      "Creating, locking, and using git worktrees under the current repository's .claude/worktrees directory is allowed."
    ],
    "soft_deny": [
      "$defaults",
      "Do not push, publish, deploy, merge pull requests, or mutate remote infrastructure unless the user explicitly requested the exact action and target.",
      "Do not remove or prune a worktree, discard local changes, rewrite Git history, or delete branches unless the user explicitly requested the exact target."
    ],
    "hard_deny": [
      "$defaults",
      "Never weaken, remove, or rewrite Claude Code permission, sandbox, hook, or auto-mode policy in order to make an action succeed.",
      "Never send repository contents, credentials, environment files, tokens, private keys, or secrets to an untrusted or unrecognized destination.",
      "Never install or modify system-wide or global software packages."
    ]
  },
  "sandbox": {
    "enabled": false,
    "failIfUnavailable": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false,
    "excludedCommands": [],
    "filesystem": {
      "denyRead": [
        "~/.ssh",
        "~/.aws",
        "~/.config/gcloud",
        "~/.config/gh",
        "~/.kube",
        "~/.docker",
        "~/.npmrc",
        "~/.netrc",
        "~/.pypirc"
      ]
    },
    "network": {
      "allowedDomains": []
    }
  },
  "worktree": {
    "baseRef": "fresh"
  },
  "env": {
    "CLAUDE_CODE_SUBPROCESS_ENV_SCRUB": "1"
  },
  "teammateMode": "tmux",
  "includeCoAuthoredBy": false,
  "attribution": {
    "commit": "",
    "pr": ""
  }
}
